# Get your free Groq key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Model to use (this one is fast and free)
GROQ_MODEL=llama-3.3-70b-versatile

# JWT secret — change this to something long and random before deploying
SAKHI_JWT_SECRET=change-me-to-something-secret

# Frontend URL (used for CORS)
FRONTEND_URL=http://localhost:3000
